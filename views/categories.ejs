<%- include('partials/header') %>

<div class="vt-categories-page">
  <h2>Browse Categories</h2>
  <div class="vt-categories-grid">
    <% categories.forEach(function(cat) { %>
      <a href="/category/<%= encodeURIComponent(cat) %>" class="vt-category-card"><%= cat %></a>
    <% }); %>
  </div>
</div>

<%- include('partials/footer') %>
