<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body class="vt-embed-body">
  <div class="vt-embed-frame">
    <video controls preload="metadata" src="/uploads/videos/<%= video.filename %>"></video>
    <div class="vt-embed-title">
      <a href="/watch?v=<%= video.id %>" target="_blank"><%= video.title %></a>
      <span>ViewTape</span>
    </div>
  </div>
</body>
</html>
